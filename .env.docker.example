# Docker Compose окружение.
# Скопируйте в .env.docker перед запуском:
#   cp .env.docker.example .env.docker

UPLOAD_DIR=/app/uploads
OBSIDIAN_VAULT=/app/obsidian_vault
OBSIDIAN_FOLDER=Встречи
REPORT_DIR=/app/reports

REDIS_URL=redis://redis:6379/0

# Для первого запуска в контейнере лучше начать с небольшой модели.
# После проверки можно заменить на medium/large-v3.
WHISPER_MODEL=base
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
# Стабильный Docker/MVP-режим: Whisper идёт на CPU/int8 даже если GPU виден.
# На RTX 4070 можно экспериментально поставить true, если worker-контейнер
# видит CUDA и faster-whisper/CTranslate2 не падает.
WHISPER_CUDA_ENABLED=false
WHISPER_FALLBACK_TO_CPU=true
WHISPERX_FALLBACK_ENABLED=false
LANGUAGE=ru

# По умолчанию выключено для стабильного CPU-запуска в Docker.
# Для диаризации нужны тяжёлые зависимости из requirements.txt и достаточно CPU/RAM/GPU.
ENABLE_DIARIZATION=false
MAX_SPEAKERS=10
DIARIZATION_MODEL=nvidia/speakerverification_en_titanet_large
DIARIZATION_DEVICE=auto
DIARIZATION_FALLBACK_TO_CPU=true

OLLAMA_MODEL=gemma3:12b
OLLAMA_HOST=http://ollama:11434

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

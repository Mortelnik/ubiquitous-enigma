# Windows-friendly пример окружения.
# Скопируйте в .env:
#   Copy-Item .env.windows.example .env

UPLOAD_DIR=uploads
OBSIDIAN_VAULT=obsidian_vault
OBSIDIAN_FOLDER=Встречи
REPORT_DIR=reports

REDIS_URL=redis://localhost:6379/0

# Для проверки сначала base/small, после подтверждения GPU можно large-v3.
# На RTX 50xx/Blackwell используйте PyTorch cu130+; ниже cu130 не опускаемся.
WHISPER_MODEL=base
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
# На RTX 50xx + cu130 Faster-Whisper/CTranslate2 CUDA может искать cublas64_12.dll
# или зависать. Для защиты MVP держим Whisper на CPU/int8.
WHISPER_CUDA_ENABLED=false
# Если Faster-Whisper CUDA падает, worker пробует WhisperX CUDA, затем CPU/int8.
WHISPER_FALLBACK_TO_CPU=true
# Практический режим для MVP: WhisperX на Windows/cu130 может зависать даже на
# коротких файлах. Оставьте false, чтобы сразу уходить на CPU/int8 fallback.
WHISPERX_FALLBACK_ENABLED=false
LANGUAGE=ru

ENABLE_DIARIZATION=true
MAX_SPEAKERS=10
DIARIZATION_MODEL=nvidia/speakerverification_en_titanet_large
DIARIZATION_DEVICE=auto
DIARIZATION_FALLBACK_TO_CPU=true

OLLAMA_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# В PowerShell можно дополнительно выставить:
#   $env:NUMEXPR_MAX_THREADS="8"
#
# Проверка CUDA PyTorch:
#   uv run python -c "import torch; print(torch.__version__, torch.version.cuda, torch.cuda.is_available(), torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'CPU')"
#
# Если torch.cuda.is_available() = False, установлен CPU-билд PyTorch.
# Для NVIDIA RTX 50xx/Blackwell используйте cu130+:
#   uv sync --extra dev --extra diarization
# или вручную:
#   uv pip uninstall torch torchvision torchaudio -y
#   uv pip install --index-url https://download.pytorch.org/whl/cu130 torch torchvision torchaudio

# ─── Скопируйте в .env и при необходимости отредактируйте ─────────────────────
# Реальные секреты сюда НЕ коммитьте. .env уже в .gitignore.

# ─── Пути ──────────────────────────────────────────────────────────────────────
# Каталог для загруженных аудио (относительный путь — от корня проекта).
UPLOAD_DIR=uploads
# Путь к вашему Obsidian vault. Можно ~/, абсолютный или относительный.
OBSIDIAN_VAULT=obsidian_vault
# Подпапка внутри vault, куда складываются заметки.
OBSIDIAN_FOLDER=Встречи
# Каталог JSONL/CSV-метрик для отчёта по MVP.
REPORT_DIR=reports

# ─── Celery / Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Whisper ─────────────────────────────────────────────────────────────────────
# Модели faster-whisper: tiny / base / small / medium / large-v3
WHISPER_MODEL=base
# auto = CUDA при доступном CUDA PyTorch, иначе CPU. Можно явно: cuda или cpu.
WHISPER_DEVICE=auto
# auto = float16 на CUDA, int8 на CPU. Можно явно: float16 / int8 / int8_float16 / float32.
WHISPER_COMPUTE_TYPE=auto
# Стабильный MVP-режим: не пробовать Faster-Whisper CUDA на Windows/RTX 50xx/cu130.
WHISPER_CUDA_ENABLED=false
# Если CUDA runtime для faster-whisper сломан, сначала пробуется WhisperX CUDA,
# затем при необходимости Faster-Whisper CPU/int8.
WHISPER_FALLBACK_TO_CPU=true
# На Windows + RTX 50xx + cu130 WhisperX может зависать. Для MVP по умолчанию
# пропускаем WhisperX и сразу уходим на Faster-Whisper CPU/int8.
WHISPERX_FALLBACK_ENABLED=false
LANGUAGE=ru

# ─── Диаризация ───────────────────────────────────────────────────────────────────
# false — пропускать тяжёлый этап NeMo (один спикер). Удобно без GPU.
ENABLE_DIARIZATION=true
MAX_SPEAKERS=10
DIARIZATION_MODEL=nvidia/speakerverification_en_titanet_large
# auto = CUDA при доступном CUDA PyTorch, иначе CPU. Можно явно: cuda или cpu.
DIARIZATION_DEVICE=auto
# Если NeMo CUDA падает из-за неподдерживаемой GPU-архитектуры, автоматически повторить на CPU.
DIARIZATION_FALLBACK_TO_CPU=true

# ─── Ollama (генерация саммари) ─────────────────────────────────────────────────
OLLAMA_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434

# ─── API / CORS ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Список разрешённых origin'ов через запятую. "*" — для локальной разработки.
CORS_ORIGINS=*
